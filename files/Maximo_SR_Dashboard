  const FNAME    = 'SR_Dashboard_Data.xlsx';
  const UPDATED  = '23 May 2026 11:43';

  try {
    UI.load('Loading SR data…');
    window._LIVE_DATA = null;

    function _showTS(ts){
      if(!ts) return;
      var d = new Date(ts);
      document.getElementById('lastUpdWrap').style.display = '';
      document.getElementById('lastUpdVal').textContent = 'Data updated: '+
        d.toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'})+' '+
        d.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
    }
    function _showModal(){
      document.getElementById('accessModal').classList.remove('hidden');
      AUTH._apply();
      setTimeout(function(){ UI.unload(); }, 400);
    }
    function _showCleared(){
      document.getElementById('emptyState').style.display = 'flex';
      document.getElementById('dash').style.display = 'none';
      document.getElementById('sidebar').classList.remove('visible');
      document.getElementById('emptyCta').style.display = 'none';
      document.getElementById('emptyHint').innerHTML =
        '<b style="color:var(--amber,#f59e0b)">Dashboard cleared by Admin</b><br>'+
        '<span style="color:var(--text2)">No data available. Waiting for Admin to upload new data.</span>';
      _showModal();
    }
    function _loadData(p){
      FILE._bootSync(p.rows, p.fname || FNAME);
      _showTS(p.ts);
      _showModal();
    }
    function _loadEmbedded(){
      FILE._bootSync(EMBEDDED, FNAME);
      document.getElementById('lastUpdWrap').style.display = '';
      document.getElementById('lastUpdVal').textContent = 'Data updated: '+UPDATED;
      _showModal();
    }

    /* Try server first — shared data for all users */
    fetch('/sr_data.json?v='+Date.now(), { cache: 'no-cache' })
    .then(function(r){ return r.ok ? r.json() : Promise.reject('no_file'); })
    .then(function(p){
      if(!p || typeof p !== 'object'){ _loadEmbedded(); return; }
      /* Admin explicitly cleared — show empty, do NOT fall back to embedded */
      if(p.cleared === true){ _showCleared(); return; }
      /* Admin uploaded data — show it */
      if(p.rows && p.rows.length > 0){
        window._LIVE_DATA = p;
        _loadData(p);
      } else {
        _loadEmbedded();
      }
    })
    .catch(function(){
      /* Server file not found (Render reset) — use embedded as default */
      _loadEmbedded();
    });

  } catch(err){
    console.warn('Load failed:', err);
    document.getElementById('emptyHint').innerHTML =
      '<b style="color:var(--red)">Error loading data</b><br>'+
      '<span style="color:var(--text2)">Please contact Aftab Ali.</span>';
    AUTH._apply();
    setTimeout(function(){ UI.unload(); }, 500);
  }
})();

