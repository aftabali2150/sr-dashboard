/* Font Size Controller */
const FSCTL = {
  _sz:13, _min:10, _max:18,
  init(){
    const stored=parseInt(localStorage.getItem('sr_fs')||'13');
    this._sz=Math.min(Math.max(stored,this._min),this._max);
    this._apply();
  },
  inc(){ if(this._sz<this._max){this._sz++;this._apply();} },
  dec(){ if(this._sz>this._min){this._sz--;this._apply();} },
  _apply(){
    document.documentElement.style.setProperty('--fs-base',this._sz+'px');
    document.documentElement.style.setProperty('--fs-sm',(this._sz-2)+'px');
    document.documentElement.style.setProperty('--fs-xs',(this._sz-3)+'px');
    document.documentElement.style.setProperty('--fs-xxs',(this._sz-3.5)+'px');
    document.body.style.fontSize=this._sz+'px';
    const el=document.getElementById('fsVal');
    if(el) el.textContent=this._sz;
    try{localStorage.setItem('sr_fs',this._sz);}catch(e){}
  },
};

