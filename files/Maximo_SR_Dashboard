/* ─────────────────────────────────────────
   4. FILE — parse & normalise
   ───────────────────────────────────────── */
const FILE = {
  drop(e){
    e.preventDefault();
    document.getElementById('upPill').classList.remove('loaded');
    if(e.dataTransfer.files[0]) this.handle(e.dataTransfer.files[0]);
  },
  handle(file){
    if(!file) return;
    UI.load('Reading file…');
    const r = new FileReader();
    r.onload = ev => {
      try {
        const isCsv = file.name.toLowerCase().endsWith('.csv');
        const wb    = isCsv
          ? XLSX.read(ev.target.result, {type:'binary'})
          : XLSX.read(new Uint8Array(ev.target.result), {type:'array'});
        const sn = wb.SheetNames.includes('Report') ? 'Report' : wb.SheetNames[0];
        UI.load('Parsing sheet: ' + sn);
        const json = XLSX.utils.sheet_to_json(wb.Sheets[sn], {defval:''});
        FILE._bootSync(json, file.name);
      } catch(err){ UI.unload(); alert('Error reading file: ' + err.message); }
    };
    file.name.toLowerCase().endsWith('.csv')
      ? r.readAsBinaryString(file) : r.readAsArrayBuffer(file);
  },
  _norm(row){
    /* Flexible column mapping — handles any header spelling */
    const keys = Object.keys(row);
    const find = (...pats) => {
      const k = keys.find(k => pats.some(p => k.toLowerCase().includes(p)));
      return k ? String(row[k]||'').trim() : '';
    };
    const exact = n => {
      const k = keys.find(k => k.toLowerCase() === n.toLowerCase());
      return k ? String(row[k]||'').trim() : '';
    };

    /* ── Day extraction helper ──────────────────────────────────────
       SheetJS gives date cells as:
         - Number: Excel serial (e.g. 25 for Jan-25-1900). The serial
           number IS the day-of-month for all Jan-1900 dates (1..31).
         - String: ISO like "1900-01-25T00:00:00.000Z"
         - JS Date object (when cellDates option used)
       We use getUTCDate() to avoid local-timezone shifts.
    ──────────────────────────────────────────────────────────────── */
    const extractDay = (val) => {
      if (!val && val !== 0) return 0;
      // Number → Excel serial for 1900-epoch dates = day of month directly
      if (typeof val === 'number') return (val >= 1 && val <= 31) ? val : 0;
      // JS Date object
      if (val instanceof Date) return isNaN(val) ? 0 : val.getUTCDate();
      // String → parse as UTC to avoid timezone issues
      const s = String(val).trim();
      if (!s) return 0;
      const d = new Date(s.includes('T') ? s : s + 'T00:00:00Z');
      return isNaN(d) ? 0 : d.getUTCDate();
    };

    // Calender column = day-of-month (Excel stores as 1900-01-DD dates)
    const calRaw = row[keys.find(k => /calend/i.test(k))];
    const calDay = extractDay(calRaw);

    // Reported Date = full datetime → extract UTC day
    const repRaw = row[keys.find(k => /reported.?date/i.test(k))];
    const repDay = extractDay(repRaw);

    // Use calDay as primary (matches 100%); fall back to repDay
    const dayNum = calDay || repDay;

    return {
      srNo           : find('sr no','sr_no') || find('sr'),
      status         : exact('status')  || find('status'),
      compliance     : exact('compliance') || find('compliance'),
      compliancePct  : parseFloat(row[keys.find(k=>/compliance\s?%/i.test(k))]||0)||0,
      month          : find('month'),
      week           : find('week'),
      raisedBy       : find('raised by','raisedby'),
      tpcSRs         : find('tpc'),
      defectCategory : find('defect'),
      department     : find('department','dept'),
      reportedBy     : find('reported by','reportedby'),
      description    : find('description'),
      wo             : find('wo'),
      calDay         : dayNum,   // day-of-month from Calender column
      reportedDay    : repDay,   // day-of-month from Reported Date
    };
  },
  _bootSync(json, fname){
    UI.load('Normalising rows…');
    S.raw = json.map(r=>this._norm(r)).filter(r=>r.srNo||r.status);
    // reset filters
    S.dayFilter = {month:'',day:0};
    S.deptSel   = '';
    S.filtered  = [...S.raw];
    FILTERS.build();
    RENDER.all();
    // Show dashboard
    document.getElementById('emptyState').style.display = 'none';
    const dash = document.getElementById('dash');
    dash.style.display = 'flex';
    document.getElementById('sidebar').classList.add('visible');
    // Topbar updates
    const short = fname.length > 24 ? fname.slice(0,22)+'…' : fname;
    document.getElementById('upPill').classList.add('loaded');
    document.getElementById('upLabel').textContent = short;
    document.getElementById('statusDot').classList.add('live');
    document.getElementById('statusLabel').textContent =
      S.raw.length.toLocaleString() + ' records loaded';
    document.getElementById('kpiBadge').textContent = S.raw.length.toLocaleString() + ' SRs';
    // Last updated timestamp
    const now = new Date();
    document.getElementById('lastUpdWrap').style.display = '';
    document.getElementById('lastUpdVal').textContent =
      now.toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'}) + ' ' +
      now.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit',second:'2-digit'});
    document.getElementById('exportBtn').style.display = '';
    const _sp = { cleared: false, rows: S.raw, fname: fname, ts: new Date().toISOString() };
    // Save to server for all users
    fetch('/save_data', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(_sp)
    }).then(function(r){
      if(r.ok){ console.log('Saved to server — all users updated'); }
      else { console.warn('Server save failed:', r.status); }
    }).catch(function(e){ console.warn('Save error:', e); });
    // Also update in-memory EMBEDDED so refresh works even if server resets
    window._LIVE_DATA = _sp;
    UI.unload();
  },
};

/* ─────────────────────────────────────────
   5. FILTERS
   ───────────────────────────────────────── */
const FILTERS = {
  /* Define which filters appear in the sidebar
     type: 'select' | 'search' | 'day'            */
  /* ── Filter order (edit to reorder sidebar filters) ─────────────
     Sequence: Defect Category → Status → Month → Day/Date →
               Raised By → TPC SRs → Department
  ──────────────────────────────────────────────────────────────── */
  DEFS : [
    {k:'defectCategory', l:'Defect Category',      type:'select'},
    {k:'status',         l:'Status',               type:'select'},
    {k:'month',          l:'Month',                type:'month'},
    {k:'_day',           l:'Day / Date Filter',    type:'day'},
    {k:'raisedBy',       l:'Raised By (CRM / PWA)',type:'select'},
    {k:'tpcSRs',         l:'TPC SRs',              type:'select'},
    {k:'department',     l:'Department',           type:'search'},
  ],

  build(){
    const c = document.getElementById('sbBody');
    c.innerHTML = '';
    this.DEFS.forEach((fd,i)=>{
      const g = document.createElement('div'); g.className = 'fg';
      if(fd.type==='select'){
        const vals = [...new Set(S.raw.map(r=>r[fd.k]).filter(Boolean))].sort();
        g.innerHTML = `<label class="fg-label">${fd.l}</label>
          <select class="f-sel" id="fs_${fd.k}" onchange="FILTERS.apply()">
            <option value="">All</option>
            ${vals.map(v=>`<option value="${v}">${v}</option>`).join('')}
          </select>`;
      } else if(fd.type==='month'){
        /* Month filter: sorted in calendar order Jan→Dec, not alphabetically */
        const presentMonths = CFG.MONTHS.filter(m=>S.raw.some(r=>r.month===m));
        g.innerHTML = `<label class="fg-label">${fd.l}</label>
          <select class="f-sel" id="fs_month" onchange="FILTERS.apply()">
            <option value="">All Months</option>
            ${presentMonths.map(m=>`<option value="${m}">${m}</option>`).join('')}
          </select>`;
      } else if(fd.type==='search'){
        const vals = [...new Set(S.raw.map(r=>r[fd.k]).filter(Boolean))].sort();
        g.innerHTML = `<label class="fg-label">${fd.l}</label>
          <div class="search-wrap">
            <input class="search-inp" id="si_${fd.k}" placeholder="Search…" autocomplete="off"
              oninput="FILTERS.searchType('${fd.k}')"
              onfocus="FILTERS.searchOpen('${fd.k}')"
              onblur="FILTERS.searchClose('${fd.k}')">
            <div class="search-drop" id="sd_${fd.k}">
              <div class="sd-item" data-val="" onmousedown="FILTERS.searchPick('${fd.k}','')">All Departments</div>
              ${vals.map(v=>`<div class="sd-item" data-val="${v}" onmousedown="FILTERS.searchPick('${fd.k}','${v}')">${v}</div>`).join('')}
            </div>
          </div>`;
      } else if(fd.type==='day'){
        g.innerHTML = `<label class="fg-label">Day / Date Filter</label>
          <div class="day-wrap">
            <button class="day-trigger" id="dayBtn" onclick="FILTERS.dayToggle()" type="button">
              <span id="dayLabel">Select specific day…</span>
              <svg width="9" height="5" fill="none" viewBox="0 0 10 6">
                <path d="M1 1l4 4 4-4" stroke="#374f68" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="day-cal" id="dayCal">
              <div class="day-cal-hdr" id="dayCalHdr">Select a month first</div>
              <div class="day-grid" id="dayGrid"></div>
            </div>
          </div>`;
      }
      c.appendChild(g);
      if(i<this.DEFS.length-1){ const s=document.createElement('div'); s.className='fg-sep'; c.appendChild(s); }
    });
  },

  apply(){
    const selMonth = document.getElementById('fs_month')?.value || '';
    S.dayFilter.month = selMonth;
    S.filtered = S.raw.filter(r=>{
      // Select + Month filters (both use <select> elements with id="fs_<key>")
      for(const fd of this.DEFS){
        if(fd.type!=='select' && fd.type!=='month') continue;
        const elId = fd.type==='month' ? 'fs_month' : 'fs_'+fd.k;
        const v = document.getElementById(elId)?.value||'';
        if(v && r[fd.k]!==v) return false;
      }
      // Dept search
      if(S.deptSel && r.department !== S.deptSel) return false;
      // Day filter — uses calDay (extracted from Calender column)
      // calDay is the day-of-month (1-31), correctly parsed from Excel serial
      if(S.dayFilter.day){
        if(S.dayFilter.month && r.month !== S.dayFilter.month) return false;
        if(r.calDay !== S.dayFilter.day) return false;
      }
      return true;
    });
    this._updateCount();
    this._updateDayCalendar();
    RENDER.all();
  },

  reset(){
    this.DEFS.forEach(fd=>{
      if(fd.type==='select'||fd.type==='month'){
        const elId=fd.type==='month'?'fs_month':'fs_'+fd.k;
        const el=document.getElementById(elId);
        if(el){el.value='';el.classList.remove('active');}
      }
    });
    const si=document.getElementById('si_department');
    if(si){si.value='';si.classList.remove('active');}
    S.deptSel=''; S.dayFilter={month:'',day:0};
    document.getElementById('dayLabel').textContent='Select specific day…';
    document.getElementById('dayBtn').classList.remove('sel');
    document.getElementById('filterCount').classList.remove('on');
    S.filtered=[...S.raw];
    RENDER.all();
  },

  _updateCount(){
    let cnt=0;
    this.DEFS.forEach(fd=>{
      if(fd.type==='select'||fd.type==='month'){
        const elId=fd.type==='month'?'fs_month':'fs_'+fd.k;
        const el=document.getElementById(elId);
        if(el?.value){el.classList.add('active');cnt++;}else el?.classList.remove('active');
      }
    });
    if(S.deptSel) cnt++;
    if(S.dayFilter.day) cnt++;
    const badge=document.getElementById('filterCount');
    badge.textContent=cnt;
    cnt>0?badge.classList.add('on'):badge.classList.remove('on');
  },

  searchType(k){
    const q=document.getElementById('si_'+k).value.toLowerCase();
    document.getElementById('sd_'+k)?.classList.add('open');
    document.querySelectorAll(`#sd_${k} .sd-item`).forEach(el=>{
      el.style.display=(el.dataset.val.toLowerCase().includes(q)||el.dataset.val==='')?'':'none';
    });
  },
  searchOpen(k){ document.getElementById('sd_'+k)?.classList.add('open'); },
  searchClose(k){ setTimeout(()=>document.getElementById('sd_'+k)?.classList.remove('open'),160); },
  searchPick(k,val){
    S.deptSel=val;
    const si=document.getElementById('si_'+k);
    if(si){si.value=val;val?si.classList.add('active'):si.classList.remove('active');}
    this.apply();
  },

  dayToggle(){ document.getElementById('dayCal').classList.toggle('open'); },
  _updateDayCalendar(){
    const m=document.getElementById('fs_month')?.value||'';
    const hdr=document.getElementById('dayCalHdr');
    const grid=document.getElementById('dayGrid');
    if(!m){hdr.textContent='Select a month first';grid.innerHTML='';S.dayFilter.day=0;this._updateDayLabel();return;}
    hdr.textContent=m;
    // Build per-day record count using ALL raw data for this month
    // (so counts show total available, not filtered totals)
    const dayCount={};
    S.raw.filter(r=>r.month===m).forEach(r=>{
      if(r.calDay > 0){ dayCount[r.calDay]=(dayCount[r.calDay]||0)+1; }
    });
    const mIdx=CFG.MONTHS.indexOf(m);
    const days=mIdx>=0?new Date(new Date().getFullYear(),mIdx+1,0).getDate():31;
    grid.innerHTML='';
    for(let d=1;d<=days;d++){
      const cnt=dayCount[d]||0;
      const cell=document.createElement('div');
      cell.className='day-cell'+(cnt>0?' has':'')+( d===S.dayFilter.day?' sel':'');
      // Show day number + record count badge below
      cell.innerHTML=`<span class="dc-num">${d}</span>${cnt>0?`<span class="dc-cnt">${cnt}</span>`:''}`;
      cell.title=cnt>0?`Day ${d}: ${cnt} record${cnt!==1?'s':''}`:(`Day ${d}: no records`);
      if(cnt>0) cell.onclick=()=>this._pickDay(m,d);
      else cell.style.opacity='0.3';
      grid.appendChild(cell);
    }
  },
  _pickDay(month,day){
    if(S.dayFilter.day===day){ S.dayFilter={month:'',day:0}; }
    else { S.dayFilter={month,day}; }
    this._updateDayLabel();
    this._updateDayCalendar();
    this.apply();
    document.getElementById('dayCal').classList.remove('open');
  },
  _updateDayLabel(){
    const lbl=document.getElementById('dayLabel');
    const btn=document.getElementById('dayBtn');
    if(S.dayFilter.day&&S.dayFilter.month){
      lbl.textContent=S.dayFilter.month+' '+S.dayFilter.day;
      btn.classList.add('sel');
    } else {
      lbl.textContent='Select specific day…';
      btn.classList.remove('sel');
    }
  },
};
