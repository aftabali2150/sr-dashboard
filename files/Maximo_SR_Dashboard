/* ─────────────────────────────────────────
   6. KPI
   ───────────────────────────────────────── */
const KPI = {
  compute(d){
    const n   = d.length;
    const cl  = d.filter(r=>/close/i.test(r.status)).length;
    const op  = d.filter(r=>/^open$/i.test(r.status)).length;
    const crm = d.filter(r=>r.raisedBy.toUpperCase()==='CRM').length;
    const pwa = d.filter(r=>r.raisedBy.toUpperCase()==='PWA').length;
    const tpc = d.filter(r=>r.tpcSRs==='TPC').length;
    const comp= d.filter(r=>r.compliance==='Compliance').length;
    const oot = d.filter(r=>r.compliance==='Closed-Out of Tolerance').length;
    const ro  = d.filter(r=>/re-?open/i.test(r.compliance)).length;
    const ov  = d.filter(r=>r.compliance==='Overdue').length;
    const cpct= n?+((cl/n)*100).toFixed(1):0;
    const cmpct=n?+((comp/n)*100).toFixed(1):0;
    // CRM Compliance: how many CRM-raised SRs are compliant
    const crmAll  = d.filter(r=>r.raisedBy.toUpperCase()==='CRM');
    const crmComp = crmAll.filter(r=>r.compliance==='Compliance').length;
    const crmCompPct = crmAll.length?+((crmComp/crmAll.length)*100).toFixed(1):0;
    // PWA Compliance: how many PWA-raised SRs are compliant
    const pwaAll  = d.filter(r=>r.raisedBy.toUpperCase()==='PWA');
    const pwaComp = pwaAll.filter(r=>r.compliance==='Compliance').length;
    const pwaCompPct = pwaAll.length?+((pwaComp/pwaAll.length)*100).toFixed(1):0;
    // Defect Category breakdown — CAT 1 and CAT2
    const cat1 = d.filter(r=>r.defectCategory==='CAT 1').length;
    const cat2 = d.filter(r=>r.defectCategory==='CAT2').length;
    const cat1Pct = n?+((cat1/n)*100).toFixed(1):0;
    const cat2Pct = n?+((cat2/n)*100).toFixed(1):0;
    // Dept breakdown
    const byDept={};
    d.forEach(r=>{ if(r.department){ byDept[r.department]=(byDept[r.department]||0)+1; } });
    const topDept=Object.entries(byDept).sort((a,b)=>b[1]-a[1])[0]||['—',0];
    // Open With Tolerance = SRs with compliance "Re-Open" (open but within tolerance)
    const openTol = d.filter(r=>r.compliance==='Re-Open').length;
    return{n,cl,op,crm,pwa,tpc,comp,oot,ro,ov,openTol,cpct,cmpct,crmComp,crmCompPct,pwaComp,pwaCompPct,cat1,cat2,cat1Pct,cat2Pct,topDept:topDept[0],topDeptN:topDept[1]};
  },

  render(k){
    /* Each card: l=label, v=value, c=colour-class, tag=badge text, tc=tag-colour */
    /* ── KPI Card Sequence (edit label/colour/value here) ─────────────
       Sequence: Total SR Raised → Closed SRs → Open SRs → Closing Rate
               → CRM Raised → PWA Raised → CRM Compliance → PWA Compliance
               → Total TPC → Cat 1 SRs → Cat 2 SRs → SR Compliance
               → Open With Tolerance → Close Out Of Tolerance → Reopened SRs
               → Overdue SRs → Compliance % → Top Department
    ────────────────────────────────────────────────────────────────── */
    const cards = [
      /* 1  */ {l:'Total SR Raised',          v:k.n,          c:'ck-blue',   tag:'All SRs',          tc:'ct-blue'},
      /* 2  */ {l:'Closed SRs',               v:k.cl,         c:'ck-green',  tag:k.cpct+'% rate',    tc:'ct-green'},
      /* 3  */ {l:'Open SRs',                 v:k.op,         c:'ck-amber',  tag:'Pending',          tc:'ct-amber'},
      /* 4  */ {l:'Closing Rate',             v:k.cpct+'%',   c:'ck-green',  tag:'Closed / Total',   tc:'ct-green', mv:true},
      /* 5  */ {l:'CRM Raised',               v:k.crm,        c:'ck-blue',   tag:k.n?Math.round(k.crm/k.n*100)+'% of total':'–', tc:'ct-blue'},
      /* 6  */ {l:'PWA Raised',               v:k.pwa,        c:'ck-purple', tag:k.n?Math.round(k.pwa/k.n*100)+'% of total':'–', tc:'ct-purple'},
      /* 7  */ {l:'CRM Compliance',           v:k.crmComp,    c:'ck-cyan',   tag:k.crmCompPct+'%',   tc:'ct-cyan'},
      /* 8  */ {l:'PWA Compliance',           v:k.pwaComp,    c:'ck-pink',   tag:k.pwaCompPct+'%',   tc:'ct-pink'},
      /* 9  */ {l:'Total TPC',                v:k.tpc,        c:'ck-yellow', tag:'TPC Flagged',      tc:'ct-yellow'},
      /* 10 */ {l:'Cat 1 SRs',               v:k.cat1,        c:'ck-purple', tag:k.cat1Pct+'% of total', tc:'ct-purple'},
      /* 11 */ {l:'Cat 2 SRs',               v:k.cat2,        c:'ck-amber',  tag:k.cat2Pct+'% of total', tc:'ct-amber'},
      /* 12 */ {l:'SR Compliance',            v:k.comp,       c:'ck-green',  tag:k.cmpct+'%',        tc:'ct-green'},
      /* 13 */ {l:'Close Out Of Tolerance',   v:k.oot,        c:'ck-red',    tag:'OOT',              tc:'ct-red'},
      /* 14 */ {l:'Compliance %',             v:k.cmpct+'%',  c:'ck-green',  tag:'Overall Rate',     tc:'ct-green', mv:true},
    ];
    document.getElementById('kpiGrid').innerHTML = cards.map((c,i)=>`
      <div class="kpi-card ${c.c} anim d${(i%8)+1}">
        <div class="kpi-stripe"></div>
        <div class="kpi-glow"></div>
        <div class="kpi-label">${c.l}</div>
        <div class="kpi-value${c.mv?' md':''}">${c.v}</div>
        <div class="kpi-footer">
          <span class="kpi-tag ${c.tc}">${c.tag}</span>
        </div>
      </div>`).join('');
  },
};

/* ─────────────────────────────────────────
   7. CHARTS
   ───────────────────────────────────────── */
const CHARTS = {
  /* Shared base options */
  BASE:{
    responsive:true, maintainAspectRatio:false,
    plugins:{
      legend:{labels:{color:'#6b87a8',font:{family:'Inter',size:10.5},boxWidth:9,padding:12}},
      tooltip:{backgroundColor:'#132438',titleColor:'#e4eaf4',bodyColor:'#6b87a8',
        borderColor:'#264566',borderWidth:1,padding:11,cornerRadius:9,
        displayColors:true,boxWidth:8,boxHeight:8},
      datalabels:{display:false},
    },
  },
  AX:{
    x:{ticks:{color:'#374f68',font:{size:10}},grid:{color:'rgba(28,48,80,.55)'},border:{display:false}},
    y:{ticks:{color:'#374f68',font:{size:10}},grid:{color:'rgba(28,48,80,.55)'},border:{display:false}},
  },

  mk(id,type,data,opts={}){
    if(this._c[id]){this._c[id].destroy();delete this._c[id];}
    const ctx=document.getElementById(id)?.getContext('2d');
    if(!ctx)return;
    this._c[id]=new Chart(ctx,{type,data,options:this._merge(this.BASE,opts),plugins:[ChartDataLabels]});
  },
  _c:S.charts,  // alias

  /* Deep-merge two plain objects */
  _merge(a,b){
    const r={...a};
    for(const k of Object.keys(b)){
      if(b[k]&&typeof b[k]==='object'&&!Array.isArray(b[k]))
        r[k]=this._merge(a[k]||{},b[k]);
      else r[k]=b[k];
    }
    return r;
  },

  /* Doughnut options helper */
  dOpts(pos='bottom'){
    return{
      cutout:'64%',
      plugins:{
        legend:{position:pos,labels:{color:'#6b87a8',font:{family:'Inter',size:10.5},boxWidth:8,padding:8}},
        tooltip:this.BASE.plugins.tooltip,
        datalabels:{
          display:true,color:'#e4eaf4',font:{weight:'700',size:10},
          formatter:(val,ctx)=>{
            const total=ctx.dataset.data.reduce((a,b)=>a+b,0);
            if(!total)return'';
            const pct=((val/total)*100).toFixed(1);
            return pct>5?`${val}\n(${pct}%)`:'';
          },
        },
      },
    };
  },

  /* Bar data-labels */
  barDL(clr){
    return{
      display:true,anchor:'end',align:'top',offset:2,
      color:clr||'#6b87a8',font:{size:9.5,weight:'600'},
      formatter:v=>v>0?v.toLocaleString():'',
    };
  },

  /* Count values */
  countBy(data,key){
    return data.reduce((acc,r)=>{const v=r[key]||'Unknown';acc[v]=(acc[v]||0)+1;return acc;},{});
  },

  renderAll(d){
    const months=CFG.MONTHS.filter(m=>d.some(r=>r.month===m));

    /* ── Status doughnut ── */
    const sc=this.countBy(d,'status'),sk=Object.keys(sc);
    this.mk('cStatus','doughnut',
      {labels:sk,datasets:[{data:sk.map(k=>sc[k]),
        backgroundColor:['#10b981','#ef4444','#f59e0b','#8b5cf6'],borderWidth:0,hoverOffset:7}]},
      this.dOpts('bottom'));

    /* ── Compliance doughnut ── */
    const cc=this.countBy(d,'compliance'),ck=Object.keys(cc);
    this.mk('cComp','doughnut',
      {labels:ck,datasets:[{data:ck.map(k=>cc[k]),
        backgroundColor:ck.map(k=>CFG.COMP_CLR[k]||'#374f68'),borderWidth:0,hoverOffset:7}]},
      this.dOpts('bottom'));

    /* ── Raised By horizontal bar ── */
    const rc=this.countBy(d,'raisedBy'),rk=Object.keys(rc);
    this.mk('cRaised','bar',
      {labels:rk,datasets:[{data:rk.map(k=>rc[k]),
        backgroundColor:['#3b82f6','#8b5cf6'],borderRadius:9,borderSkipped:false}]},
      {indexAxis:'y',
       plugins:{legend:{display:false},tooltip:this.BASE.plugins.tooltip,
         datalabels:{display:true,anchor:'end',align:'right',
           color:'#6b87a8',font:{size:10,weight:'700'},formatter:v=>v.toLocaleString()}},
       scales:{x:this.AX.x,y:{...this.AX.y,grid:{display:false}}}});

    /* ── TPC doughnut ── */
    const tpcY=d.filter(r=>r.tpcSRs==='TPC').length;
    this.mk('cTPC','doughnut',
      {labels:['TPC','Non-TPC'],datasets:[{data:[tpcY,d.length-tpcY],
        backgroundColor:['#eab308','#1c3050'],borderWidth:0,hoverOffset:7}]},
      this.dOpts('bottom'));

    /* ── Smart Trend ── */
    this._renderTrend(d,months);

    /* ── Defect bar ── */
    const dc=this.countBy(d,'defectCategory'),dk=Object.keys(dc);
    this.mk('cDefect','bar',
      {labels:dk,datasets:[{label:'SRs',data:dk.map(k=>dc[k]),
        backgroundColor:CFG.PAL.slice(0,dk.length),borderRadius:8,borderSkipped:false}]},
      {plugins:{legend:{display:false},tooltip:this.BASE.plugins.tooltip,datalabels:this.barDL()},
       scales:{x:{...this.AX.x,grid:{display:false}},y:this.AX.y}});

    /* ── Department horizontal bar ── */
    const deptCts=this.countBy(d,'department');
    const depts=Object.keys(deptCts).sort((a,b)=>deptCts[b]-deptCts[a]);
    this.mk('cDept','bar',
      {labels:depts,datasets:[{label:'SRs',data:depts.map(k=>deptCts[k]),
        backgroundColor:depts.map(k=>CFG.DEPT_CLR[k]||'#3b82f6'),borderRadius:8,borderSkipped:false}]},
      {indexAxis:'y',
       plugins:{legend:{display:false},tooltip:this.BASE.plugins.tooltip,
         datalabels:{display:true,anchor:'end',align:'right',
           color:'#6b87a8',font:{size:9.5,weight:'700'},formatter:v=>v.toLocaleString()}},
       scales:{x:this.AX.x,y:{...this.AX.y,grid:{display:false},
         ticks:{...this.AX.y.ticks,font:{size:10.5}}}}});

    /* ── CRM vs PWA monthly ── */
    this.mk('cCrmPwa','bar',
      {labels:months,datasets:[
        {label:'CRM',data:months.map(m=>d.filter(r=>r.month===m&&r.raisedBy.toUpperCase()==='CRM').length),
          backgroundColor:'rgba(59,130,246,.8)',borderRadius:6},
        {label:'PWA',data:months.map(m=>d.filter(r=>r.month===m&&r.raisedBy.toUpperCase()==='PWA').length),
          backgroundColor:'rgba(139,92,246,.8)',borderRadius:6},
      ]},
      {plugins:{legend:this.BASE.plugins.legend,tooltip:this.BASE.plugins.tooltip,
        datalabels:this.barDL()},scales:this.AX});

    /* ── Compliance % Trend — monthly or daily based on month filter ── */
    this._renderCompTrend(d,months);

    /* ── OOT Trend — dynamic (monthly or daily when month selected) ── */
    this._renderOOT(d, months);

    /* ── Dept × Month multi-line ── */
    this._renderDeptMonth(d,months);
  },

  /* Smart Trend: monthly totals line OR daily totals bar based on filter */
  _renderTrend(d,months){
    const selMonth=document.getElementById('fs_month')?.value||'';
    const title=document.getElementById('trendTitle');
    const sub=document.getElementById('trendSub');
    const pill=document.getElementById('trendPill');

    if(!selMonth){
      /* No month selected → show full monthly trend (total WOs per month) */
      title.textContent='Monthly SR Trend';
      sub.textContent='Total work orders raised per month';
      pill.textContent='📅 Monthly';
      pill.className='cc-tag dynamic';
      const totals=months.map(m=>d.filter(r=>r.month===m).length);
      this.mk('cTrend','line',
        {labels:months,datasets:[
          {label:'Total WOs Raised',data:totals,
            borderColor:'#3b82f6',backgroundColor:'rgba(59,130,246,.10)',
            fill:true,tension:.4,pointBackgroundColor:'#3b82f6',
            pointRadius:5,pointHoverRadius:9,borderWidth:2.5},
        ]},
        {plugins:{legend:{display:false},tooltip:this.BASE.plugins.tooltip,
          datalabels:{display:true,align:'top',font:{size:9.5,weight:'700'},
            color:'#3b82f6',formatter:v=>v>0?v.toLocaleString():''}},
         scales:{x:{...this.AX.x,grid:{display:false}},y:this.AX.y}});
    } else {
      /* Month selected → show day-by-day totals for that month */
      title.textContent=selMonth+' — Daily SR Trend';
      sub.textContent='Total work orders raised per day in '+selMonth;
      pill.textContent='📆 Daily';
      pill.className='cc-tag dynamic';
      const mData=d.filter(r=>r.month===selMonth);
      /* Use calDay (primary) with fallback to reportedDay */
      const daySet=new Set();
      mData.forEach(r=>{ const day=r.calDay||r.reportedDay; if(day>0) daySet.add(day); });
      const days=[...daySet].sort((a,b)=>a-b);
      const totals=days.map(day=>mData.filter(r=>(r.calDay===day)||(r.calDay===0&&r.reportedDay===day)).length);
      this.mk('cTrend','bar',
        {labels:days.map(d=>'Day '+d),datasets:[
          {label:'Total WOs Raised',data:totals,
            backgroundColor:'rgba(59,130,246,.85)',
            borderColor:'rgba(59,130,246,1)',
            borderWidth:1,borderRadius:6,borderSkipped:false},
        ]},
        {plugins:{legend:{display:false},tooltip:this.BASE.plugins.tooltip,
          datalabels:{display:true,anchor:'end',align:'top',
            font:{size:9,weight:'700'},color:'#3b82f6',
            formatter:v=>v>0?v.toLocaleString():''}},
         scales:{x:{...this.AX.x,grid:{display:false}},y:this.AX.y}});
    }
  },

  /* ─── Compliance % Trend: monthly OR day-by-day when month selected ─── */
  _renderCompTrend(d,months){
    const selMonth = document.getElementById('fs_month')?.value||'';
    const compTitle = document.getElementById('compTrendTitle');
    const compSub   = document.getElementById('compTrendSub');
    const compTag   = document.getElementById('compTrendTag');

    /* Shared gradient builder */
    const greenGrad = ctx2 => {
      const ch = ctx2.chart;
      const {ctx:c2, chartArea} = ch;
      if(!chartArea) return 'rgba(16,185,129,.08)';
      const gr = c2.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);
      gr.addColorStop(0,'rgba(16,185,129,.28)');
      gr.addColorStop(1,'rgba(16,185,129,.01)');
      return gr;
    };

    if(!selMonth){
      /* ── ALL MONTHS → monthly compliance % ── */
      if(compTitle) compTitle.textContent = 'Compliance Rate Trend';
      if(compSub)   compSub.textContent   = 'Monthly compliance % — select a month for daily view';
      if(compTag){  compTag.textContent   = '📅 Monthly'; compTag.className = 'cc-tag dynamic'; }

      const labels = months;
      const vals   = months.map(m => {
        const md = d.filter(r=>r.month===m);
        return md.length ? +((md.filter(r=>r.compliance==='Compliance').length / md.length)*100).toFixed(1) : 0;
      });

      this.mk('cCompTrend','line',
        {labels, datasets:[{
          label:'Compliance %', data:vals,
          borderColor:'#10b981', backgroundColor:greenGrad,
          fill:true, tension:.4,
          pointBackgroundColor:'#10b981', pointBorderColor:'#0f1e30',
          pointBorderWidth:2, pointRadius:6, pointHoverRadius:10,
          borderWidth:2.5,
        }]},
        {plugins:{
          legend:{display:false},
          tooltip:{...this.BASE.plugins.tooltip,callbacks:{label:ctx=>' '+ctx.parsed.y.toFixed(1)+'%'}},
          datalabels:{
            display:true, align:'top', offset:8,
            color:'#10b981', font:{size:11, weight:'700'},
            formatter: v => v > 0 ? v.toFixed(1)+'%' : '',
          },
        },
        scales:{
          x:{...this.AX.x, grid:{display:false},
             ticks:{...this.AX.x.ticks, font:{size:11}, color:'#6b87a8'}},
          y:{...this.AX.y, min:0, max:100,
             ticks:{...this.AX.y.ticks, callback:v=>v+'%', font:{size:11}, color:'#6b87a8'},
             grid:{color:'rgba(28,48,80,.4)'}},
        },
        layout:{padding:{top:32, right:16, bottom:8, left:8}},
        });

    } else {
      /* ── SPECIFIC MONTH → day-by-day compliance % ── */
      if(compTitle) compTitle.textContent = selMonth + ' — Daily Compliance Trend';
      if(compSub)   compSub.textContent   = 'Day-by-day compliance % for ' + selMonth;
      if(compTag){  compTag.textContent   = '📆 Daily'; compTag.className = 'cc-tag dynamic'; }

      const mData = d.filter(r=>r.month===selMonth);
      const daySet = new Set();
      mData.forEach(r=>{ const day=r.calDay||r.reportedDay; if(day>0) daySet.add(day); });
      const days = [...daySet].sort((a,b)=>a-b);

      const vals = days.map(day=>{
        const dayRows = mData.filter(r=>(r.calDay===day)||(r.calDay===0&&r.reportedDay===day));
        if(!dayRows.length) return null;
        return +((dayRows.filter(r=>r.compliance==='Compliance').length / dayRows.length)*100).toFixed(1);
      });

      this.mk('cCompTrend','line',
        {labels: days.map(d=>'Day '+d),
         datasets:[{
          label:'Compliance %', data:vals,
          borderColor:'#10b981', backgroundColor:greenGrad,
          fill:true, tension:.4,
          pointBackgroundColor:'#10b981', pointBorderColor:'#0f1e30',
          pointBorderWidth:2, pointRadius:6, pointHoverRadius:10,
          borderWidth:2.5, spanGaps:false,
        }]},
        {plugins:{
          legend:{display:false},
          tooltip:{...this.BASE.plugins.tooltip,callbacks:{label:ctx=>' '+ctx.parsed.y.toFixed(1)+'%'}},
          datalabels:{
            display:true, align:'top', offset:8,
            color:'#10b981', font:{size:11, weight:'700'},
            formatter: v => (v !== null && v > 0) ? v.toFixed(1)+'%' : '',
          },
        },
        scales:{
          x:{...this.AX.x, grid:{display:false},
             ticks:{...this.AX.x.ticks, font:{size:11}, color:'#6b87a8', maxRotation:45}},
          y:{...this.AX.y, min:0, max:100,
             ticks:{...this.AX.y.ticks, callback:v=>v+'%', font:{size:11}, color:'#6b87a8'},
             grid:{color:'rgba(28,48,80,.4)'}},
        },
        layout:{padding:{top:32, right:16, bottom:8, left:8}},
        });
    }
  },

  /* ─── OOT Trend: monthly OR day-by-day when month selected ─── */
  _renderOOT(d, months){
    const selMonth = document.getElementById('fs_month')?.value||'';
    const ootTitle = document.getElementById('ootTitle');
    const ootSub   = document.getElementById('ootSub');
    const ootTag   = document.getElementById('ootTag');

    const amberGrad = ctx2 => {
      const ch = ctx2.chart;
      const {ctx:c2, chartArea} = ch;
      if(!chartArea) return 'rgba(245,158,11,.08)';
      const gr = c2.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);
      gr.addColorStop(0,'rgba(245,158,11,.25)');
      gr.addColorStop(1,'rgba(245,158,11,.01)');
      return gr;
    };

    if(!selMonth){
      /* ── ALL MONTHS → monthly OOT counts ── */
      if(ootTitle) ootTitle.textContent = 'Close Out of Tolerance Trend';
      if(ootSub)   ootSub.textContent   = 'Monthly OOT SR count — select a month for daily view';
      if(ootTag){  ootTag.textContent   = '📅 Monthly'; ootTag.className = 'cc-tag dynamic'; }

      const vals = months.map(m => d.filter(r=>r.month===m&&r.compliance==='Closed-Out of Tolerance').length);

      this.mk('cRisk','line',
        {labels: months,
         datasets:[{
          label:'Close Out of Tolerance', data:vals,
          borderColor:'#f59e0b', backgroundColor:amberGrad,
          fill:true, tension:.4,
          pointBackgroundColor:'#f59e0b', pointBorderColor:'#0f1e30',
          pointBorderWidth:2, pointRadius:6, pointHoverRadius:10,
          borderWidth:2.5,
        }]},
        {plugins:{
          legend:{display:false},
          tooltip:this.BASE.plugins.tooltip,
          datalabels:{
            display:true, align:'top', offset:8,
            color:'#f59e0b', font:{size:11, weight:'700'},
            formatter: v => v > 0 ? v : '',
          },
        },
        scales:{
          x:{...this.AX.x, grid:{display:false},
             ticks:{...this.AX.x.ticks, font:{size:11}, color:'#6b87a8'}},
          y:{...this.AX.y, beginAtZero:true,
             ticks:{...this.AX.y.ticks, font:{size:11}, color:'#6b87a8',
               callback:v=>Number.isInteger(v)?v:''},
             grid:{color:'rgba(28,48,80,.4)'}},
        },
        layout:{padding:{top:32, right:16, bottom:8, left:8}},
        });

    } else {
      /* ── SPECIFIC MONTH → day-by-day OOT counts ── */
      if(ootTitle) ootTitle.textContent = selMonth + ' — Daily OOT Trend';
      if(ootSub)   ootSub.textContent   = 'Day-by-day Close Out of Tolerance for ' + selMonth;
      if(ootTag){  ootTag.textContent   = '📆 Daily'; ootTag.className = 'cc-tag dynamic'; }

      const mData = d.filter(r=>r.month===selMonth);
      const daySet = new Set();
      mData.forEach(r=>{ const day=r.calDay||r.reportedDay; if(day>0) daySet.add(day); });
      const days = [...daySet].sort((a,b)=>a-b);

      const vals = days.map(day=>{
        const dayRows = mData.filter(r=>(r.calDay===day)||(r.calDay===0&&r.reportedDay===day));
        return dayRows.filter(r=>r.compliance==='Closed-Out of Tolerance').length;
      });

      this.mk('cRisk','line',
        {labels: days.map(d=>'Day '+d),
         datasets:[{
          label:'Close Out of Tolerance', data:vals,
          borderColor:'#f59e0b', backgroundColor:amberGrad,
          fill:true, tension:.4,
          pointBackgroundColor:'#f59e0b', pointBorderColor:'#0f1e30',
          pointBorderWidth:2, pointRadius:6, pointHoverRadius:10,
          borderWidth:2.5,
        }]},
        {plugins:{
          legend:{display:false},
          tooltip:this.BASE.plugins.tooltip,
          datalabels:{
            display:true, align:'top', offset:8,
            color:'#f59e0b', font:{size:11, weight:'700'},
            formatter: v => v > 0 ? v : '',
          },
        },
        scales:{
          x:{...this.AX.x, grid:{display:false},
             ticks:{...this.AX.x.ticks, font:{size:11}, color:'#6b87a8', maxRotation:45}},
          y:{...this.AX.y, beginAtZero:true,
             ticks:{...this.AX.y.ticks, font:{size:11}, color:'#6b87a8',
               callback:v=>Number.isInteger(v)?v:''},
             grid:{color:'rgba(28,48,80,.4)'}},
        },
        layout:{padding:{top:32, right:16, bottom:8, left:8}},
        });
    }
  },

  /* Department × Month — individual column chart per department */
  _renderDeptMonth(d,months){
    const depts=[...new Set(d.map(r=>r.department).filter(Boolean))].sort();
    const container=document.getElementById('deptMonthContainer');
    if(!container) return;

    // Clear previous chart instances for all dept charts
    Object.keys(this._c).filter(k=>k.startsWith('cDM_')).forEach(k=>{
      if(this._c[k]){this._c[k].destroy();delete this._c[k];}
    });

    if(!depts.length){
      container.innerHTML=`<div style="padding:40px;text-align:center;color:var(--text3);font-size:12px">No department data available</div>`;
      return;
    }

    // Build one card per department
    container.innerHTML=depts.map(dep=>{
      const clr=CFG.DEPT_CLR[dep]||'#3b82f6';
      const safeId='cDM_'+dep.replace(/[^a-zA-Z0-9]/g,'_');
      return`<div class="chart-card dept-ind-card anim d1">
        <div class="cc-hdr">
          <div>
            <div class="cc-title" style="display:flex;align-items:center;gap:8px">
              <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:${clr};flex-shrink:0"></span>
              ${dep}
            </div>
            <div class="cc-sub">Monthly WO volume</div>
          </div>
          <span class="cc-tag">Column</span>
        </div>
        <div class="chart-box h185"><canvas id="${safeId}"></canvas></div>
      </div>`;
    }).join('');

    // Render each individual chart
    depts.forEach(dep=>{
      const clr=CFG.DEPT_CLR[dep]||'#3b82f6';
      const safeId='cDM_'+dep.replace(/[^a-zA-Z0-9]/g,'_');
      const vals=months.map(m=>d.filter(r=>r.department===dep&&r.month===m).length);
      const maxVal=Math.max(...vals,1);
      const ctx=document.getElementById(safeId)?.getContext('2d');
      if(!ctx) return;
      this._c[safeId]=new Chart(ctx,{
        type:'bar',
        data:{
          labels:months.map(m=>m.slice(0,3)),
          datasets:[{
            label:dep,
            data:vals,
            backgroundColor:clr+'cc',
            borderColor:clr,
            borderWidth:1.5,
            borderRadius:6,
            borderSkipped:false,
          }]
        },
        options:this._merge(this.BASE,{
          plugins:{
            legend:{display:false},
            tooltip:this.BASE.plugins.tooltip,
            datalabels:{
              display:true,anchor:'end',align:'top',offset:2,
              color:clr,font:{size:9.5,weight:'700'},
              formatter:v=>v>0?v.toLocaleString():'',
            },
          },
          scales:{
            x:{...this.AX.x,grid:{display:false}},
            y:{...this.AX.y,min:0,suggestedMax:maxVal+Math.ceil(maxVal*0.15)},
          },
        }),
        plugins:[ChartDataLabels],
      });
    });
  },
};
// keep alias in sync
CHARTS._c = S.charts;

/* ─────────────────────────────────────────
   8. GAUGE
   ───────────────────────────────────────── */
const GAUGE = {
  draw(pct){
    const cv=document.getElementById('cGauge');
    if(!cv)return;
    const ctx=cv.getContext('2d');
    const W=cv.width,H=cv.height;
    ctx.clearRect(0,0,W,H);
    const cx=W/2,cy=H+6,r=H-12;
    const sa=Math.PI,ea=2*Math.PI;
    const va=sa+(Math.min(Math.max(pct,0),100)/100)*(ea-sa);
    // track
    ctx.beginPath();ctx.arc(cx,cy,r,sa,ea);
    ctx.lineWidth=15;ctx.strokeStyle='#1c3050';ctx.lineCap='round';ctx.stroke();
    // fill
    const g=ctx.createLinearGradient(cx-r,0,cx+r,0);
    g.addColorStop(0,'#dc2626');g.addColorStop(.5,'#f59e0b');g.addColorStop(1,'#10b981');
    ctx.beginPath();ctx.arc(cx,cy,r,sa,va);
    ctx.lineWidth=15;ctx.strokeStyle=g;ctx.lineCap='round';ctx.stroke();
    // labels
    ctx.font='bold 10px Inter';ctx.fillStyle='#374f68';ctx.textAlign='left';
    ctx.fillText('0%',cx-r-4,cy+8);ctx.textAlign='right';ctx.fillText('100%',cx+r+4,cy+8);
    document.getElementById('gaugePct').textContent=pct.toFixed(1)+'%';
  },
};

/* ─────────────────────────────────────────
   9. TABLE
   ───────────────────────────────────────── */
const TABLE = {
  render(d){
    const months=CFG.MONTHS.filter(m=>d.some(r=>r.month===m));
    document.getElementById('tblBody').innerHTML=months.map(m=>{
      const md=d.filter(r=>r.month===m),n=md.length;
      const cl=md.filter(r=>/close/i.test(r.status)).length;
      const op=md.filter(r=>/^open$/i.test(r.status)).length;
      const co=md.filter(r=>r.compliance==='Compliance').length;
      const ot=md.filter(r=>r.compliance==='Closed-Out of Tolerance').length;
      const ov=md.filter(r=>r.compliance==='Overdue').length;
      const ro=md.filter(r=>/re-?open/i.test(r.compliance)).length;
      const tpc=md.filter(r=>r.tpcSRs==='TPC').length;
      const p=n?((co/n)*100).toFixed(1):0;
      const pc=p>=90?'b-grn':p>=70?'b-blu':p>=50?'b-amb':'b-red';
      return`<tr>
        <td class="td-m">${m}</td>
        <td class="td-n">${n.toLocaleString()}</td>
        <td><span class="badge b-grn">${cl.toLocaleString()}</span></td>
        <td><span class="badge b-amb">${op.toLocaleString()}</span></td>
        <td><span class="badge b-blu">${co.toLocaleString()}</span></td>
        <td><span class="badge b-red">${ot.toLocaleString()}</span></td>
        <td><span class="badge b-red">${ov.toLocaleString()}</span></td>
        <td><span class="badge b-pur">${ro.toLocaleString()}</span></td>
        <td><span class="badge b-cyn">${tpc.toLocaleString()}</span></td>
        <td><span class="badge ${pc}">${p}%</span></td>
      </tr>`;
    }).join('');
  },
};

