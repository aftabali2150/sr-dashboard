<!-- ═══════════════ SCRIPTS ═══════════════ -->
<script>
'use strict';
/* ╔══════════════════════════════════════════════════════════╗
   ║   MAXIMO SR DASHBOARD — v4.0                           ║
   ║   Sections:                                            ║
   ║   1. CONFIG      Constants, credentials, colour maps   ║
   ║   2. STATE       Global data variables                 ║
   ║   3. AUTH        Login / logout / role management      ║
   ║   4. FILE        Excel/CSV parse & normalise           ║
   ║   5. FILTERS     Build sidebar & instant-react         ║
   ║   6. KPI         Compute & render KPI cards            ║
   ║   7. CHARTS      All Chart.js instances                ║
   ║   8. GAUGE       Canvas gauge                          ║
   ║   9. TABLE       Monthly summary table                 ║
   ║  10. RENDER      Master render dispatcher              ║
   ║  11. EXPORT      Excel report export                   ║
   ║  12. UI          Dark mode, loading, helpers           ║
   ╚══════════════════════════════════════════════════════════╝ */

/* ─────────────────────────────────────────
   1. CONFIG
   ─────────────────────────────────────────
   ⚠ Change ADMIN_USER / ADMIN_PASS below   */
const CFG = {
  ADMIN_USER : 'admin',
  ADMIN_PASS : 'admin123',

  MONTHS : ['January','February','March','April','May','June',
            'July','August','September','October','November','December'],

  /* Compliance type → colour */
  COMP_CLR : {
    'Compliance'              : '#10b981',
    'Closed-Out of Tolerance' : '#ef4444',
    'Overdue'                 : '#f59e0b',
    'Re-Open'                 : '#8b5cf6',
    'Closed – Re-Open WO'     : '#06b6d4',
  },

  /* Ordered palette for charts */
  PAL : ['#3b82f6','#10b981','#f59e0b','#8b5cf6','#06b6d4',
         '#ef4444','#eab308','#ec4899','#14b8a6','#f97316'],

  /* Dept colour map (consistent across all dept charts) */
  DEPT_CLR : {
    'Street Light' : '#3b82f6',
    'Road Safety'  : '#10b981',
    'Pavement'     : '#f59e0b',
    'ITS/TS'       : '#8b5cf6',
    'MEP'          : '#06b6d4',
    'Structures'   : '#ec4899',
  },
};

/* ─────────────────────────────────────────
   2. STATE
   ───────────────────────────────────────── */
let S = {
  raw       : [],   // full parsed rows
  filtered  : [],   // after filters applied
  charts    : {},   // Chart.js instances
  isAdmin   : false,
  dayFilter : { month:'', day:0 },
  deptSel   : '',
};

/* ─────────────────────────────────────────
   3. ACCESS — Choice modal + AUTH
   ───────────────────────────────────────── */

/* ACCESS: manages the initial choice modal */
const ACCESS = {
  viewer(){
    /* Hide access modal, enter as viewer (read-only) */
    document.getElementById('accessModal').classList.add('hidden');
    S.isAdmin = false;
    AUTH._apply();

    if(S.raw.length){
      /* ── Data already in memory (admin uploaded this session) → show dashboard ── */
      S.filtered = [...S.raw];
      document.getElementById('emptyState').style.display = 'none';
      const dash = document.getElementById('dash');
      dash.style.display = 'flex';
      document.getElementById('sidebar').classList.add('visible');
      FILTERS.build();
      RENDER.all();
      /* Update status bar */
      document.getElementById('statusDot').classList.add('live');
      document.getElementById('statusLabel').textContent =
        S.raw.length.toLocaleString() + ' records loaded';
      document.getElementById('exportBtn').style.display = '';
    } else {
      /* No data yet — friendly viewer empty state */
      document.getElementById('emptyState').style.display = 'flex';
